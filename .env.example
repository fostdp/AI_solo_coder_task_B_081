# ========== MongoDB ==========
MONGO_USER=admin
MONGO_PASSWORD=password

# ========== Neo4j ==========
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== FastAPI 服务 ==========
GUNICORN_WORKERS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ========== 数据模拟器 ==========
SIM_NUM_FORMULAS=5000
SIM_NUM_TARGETS=100
SIM_SEED=42
SIM_CLEAR_BEFORE=true
